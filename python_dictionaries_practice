def create_dictionary(name,month,year,wind,area,damage,deaths):
  new_dict = {}
  for i in range(len(names)):
    new_dict[name[i]] = {'Month': month[i], 'Year': year[i], 'Max Sustained Wind': wind[i], 'Areas Affected': area[i], 'Damage': damage[i], 'Deaths':deaths[i]}
