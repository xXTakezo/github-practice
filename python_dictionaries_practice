def damage_counter(dictionary):
  damage_counter = 0
  hurrican_name = ''
  for record in dictionary:
    if dictionary[record]['Damage'] == 'Damages not recorded':
      continue
    elif dictionary[record]['Damage'] > damage_counter:
      damage_counter = dictionary[record]['Damage']
      hurrican_name = record
  return damage_counter, hurrican_name




