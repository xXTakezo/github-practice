# test function by updating damages
def updated_damage(lst):
  new_lst = []
  for i in lst:
    if i == 'Damages not recorded':
      new_lst.append(i)
    elif 'M' in i:
      a1 = i.replace('M','')
      a2 = float(a1) * conversion['M']
      new_lst.append(a2)
    elif 'B' in i:
      b1 = i.replace('B','')
      b2 = float(b1) * conversion['B']
      new_lst.append(b2)
  return new_lst

