def critical_damage(dictionary):
  death_count = 0
  hurricane_name = ''
  for hurrican_namea in dictionary:
    if dictionary[hurrican_namea]['Deaths'] > death_count:
      hurricane_name = hurrican_namea
      death_count = dictionary[hurrican_namea]['Deaths']
  return death_count, hurricane_name
      


